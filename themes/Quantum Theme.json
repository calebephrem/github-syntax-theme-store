{
  "$schema": "https://raw.githubusercontent.com/calebephrem/github-syntax-theme-store/refs/heads/main/schema.json",
  "name": "Quantum Theme",
  "description": "Beautify your workspace with the best combos of blue, lime, yellow, purple and cyan accents",
  "author": "calebephrem",
  "type": "dark",
  "icon": "https://raw.githubusercontent.com/calebephrem/quantum-vscode/refs/heads/main/assets/icon.png",

  "syntaxHighlighting": {
    "comment": "#ffffff70",
    "constant": "#ffdd70",
    "constantNumeric": "#00ddee",
    "constantBuiltin": "#ffdd70",
    "keyword": "#86ff72",
    "keywordControl": "#86ff72",
    "string": "#aaff4f",
    "stringRegexp": "#00ddee",
    "variable": "#c0c0ff",
    "variableBuiltin": "#39bae6",
    "functionName": "#3f9fff",
    "typeName": "#59c2ff",
    "attribute": "#ffdd70",
    "tag": "#00aaff",
    "punctuation": "#8672ff",
    "markupHeading": "#ffdd70",
    "markupBold": "#49a2ff",
    "markupItalic": "#a090ff",
    "markupLink": "#60f060",
    "markupCode": "#ffdd70",
    "diffInserted": "#7fd962",
    "diffDeleted": "#f26d78",
    "invalid": "#ff5050"
  }
}
