{
  "$schema": "https://raw.githubusercontent.com/calebephrem/github-syntax-theme-store/refs/heads/main/schema.json",
  "name": "One Dark Pro",
  "description": "Atom's iconic One Dark theme, ported to GitHub. Deep grays with vibrant syntax colors.",
  "author": "calebephrem",
  "type": "dark",

  "syntaxHighlighting": {
    "comment": "#7f848e",
    "constant": "#d19a66",
    "constantNumeric": "#d19a66",
    "constantBuiltin": "#56b6c2",
    "keyword": "#c678dd",
    "keywordControl": "#c678dd",
    "keywordOperator": "#abb2bf",
    "operator": "#56b6c2",
    "string": "#98c379",
    "stringRegexp": "#e06c75",
    "stringEscape": "#56b6c2",
    "stringSpecial": "#98c379",
    "variable": "#e06c75",
    "variableParameter": "#d19a66",
    "variableBuiltin": "#e5c07b",
    "functionName": "#61afef",
    "functionCall": "#61afef",
    "functionBuiltin": "#56b6c2",
    "typeName": "#e5c07b",
    "typeBuiltin": "#e5c07b",
    "typeAnnotation": "#e5c07b",
    "namespace": "#e5c07b",
    "attribute": "#d19a66",
    "attributeValue": "#98c379",
    "tag": "#e06c75",
    "tagPunctuation": "#abb2bf",
    "decorator": "#61afef",
    "punctuation": "#abb2bf",
    "bracket": "#abb2bf",
    "property": "#e06c75",
    "cssProperty": "#56b6c2",
    "cssValue": "#d19a66",
    "cssUnit": "#e06c75",
    "cssSelector": "#d19a66",
    "cssPseudo": "#56b6c2",
    "markupHeading": "#e06c75",
    "markupBold": "#d19a66",
    "markupItalic": "#c678dd",
    "markupCode": "#98c379",
    "markupLink": "#61afef",
    "markupLinkUrl": "#c678dd",
    "markupQuote": "#5c6370",
    "markupList": "#e5c07b",
    "diffInserted": "#98c379",
    "diffDeleted": "#e06c75",
    "invalid": "#ffffff",
    "deprecated": "#ffffff",
    "meta": "#61afef"
  }
}
