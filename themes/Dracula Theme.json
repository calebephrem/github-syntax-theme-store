{
  "$schema": "https://raw.githubusercontent.com/calebephrem/github-syntax-theme-store/refs/heads/main/schema.json",
  "name": "Dracula Theme",
  "description": "Classic dark theme with vibrant syntax colors adapted for GitHub syntax highlighting",
  "author": "calebephrem",
  "type": "dark",
  "icon": "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRJYZxU-NcLsY0iEj3re9Vn48Nwa__m3Jj9bw&s",
  "syntaxHighlighting": {
    "comment": "#6272a4",
    "constant": "#bd93f9",
    "constantNumeric": "#bd93f9",
    "constantBuiltin": "#bd93f9",
    "keyword": "#ff79c6",
    "keywordControl": "#ff79c6",
    "keywordOperator": "#ff79c6",
    "operator": "#ff79c6",
    "string": "#f1fa8c",
    "stringRegexp": "#f1fa8c",
    "stringEscape": "#ffb86c",
    "stringSpecial": "#ffb86c",
    "variable": "#50fa7b",
    "variableParameter": "#8be9fd",
    "variableBuiltin": "#8be9fd",
    "functionName": "#50fa7b",
    "functionCall": "#50fa7b",
    "functionBuiltin": "#8be9fd",
    "typeName": "#8be9fd",
    "typeBuiltin": "#8be9fd",
    "typeAnnotation": "#8be9fd",
    "namespace": "#8be9fd",
    "attribute": "#ffb86c",
    "attributeValue": "#f1fa8c",
    "tag": "#ff79c6",
    "tagPunctuation": "#f8f8f2",
    "decorator": "#bd93f9",
    "punctuation": "#f8f8f2",
    "bracket": "#f8f8f2",
    "property": "#50fa7b",
    "cssProperty": "#8be9fd",
    "cssValue": "#f1fa8c",
    "cssUnit": "#ffb86c",
    "cssSelector": "#ff79c6",
    "cssPseudo": "#bd93f9",
    "markupHeading": "#ff79c6",
    "markupBold": "#ff79c6",
    "markupItalic": "#f1fa8c",
    "markupCode": "#f1fa8c",
    "markupLink": "#8be9fd",
    "markupLinkUrl": "#8be9fd",
    "markupQuote": "#6272a4",
    "markupList": "#ff79c6",
    "diffInserted": "#50fa7b",
