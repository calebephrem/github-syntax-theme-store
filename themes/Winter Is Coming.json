{
  "$schema": "https://raw.githubusercontent.com/calebephrem/github-syntax-theme-store/refs/heads/main/schema.json",
  "name": "Winter Is Coming",
  "description": "Cool, crisp dark theme with icy blues and soft highlights for GitHub syntax highlighting",
  "author": "calebephrem",
  "type": "dark",
  "syntaxHighlighting": {
    "comment": "#999999",
    "constant": "#A170C6",
    "constantNumeric": "#8dec95",
    "constantBuiltin": "#92b6f4",
    "keyword": "#00bff9",
    "keywordControl": "#00bff9",
    "keywordOperator": "#00bff9",
    "operator": "#00bff9",
    "string": "#bcf0c0",
    "stringRegexp": "#c63ed3",
    "stringEscape": "#fff",
    "stringSpecial": "#c63ed3",
    "variable": "#a4ceee",
    "variableParameter": "#d7dbe0",
    "variableBuiltin": "#6dbdfa",
    "functionName": "#87aff4",
    "functionCall": "#87aff4",
    "functionBuiltin": "#f7ecb5",
    "typeName": "#d29ffc",
    "typeBuiltin": "#7fdbca",
    "typeAnnotation": "#d29ffc",
    "namespace": "#4FB4D8",
    "attribute": "#f7ecb5",
    "attributeValue": "#f7ecb5",
    "tag": "#6dbdfa",
    "tagPunctuation": "#ffffff",
    "decorator": "#f7ecb5",
    "punctuation": "#ffffff",
    "bracket": "#ffffff",
    "property": "#f7ecb5",
    "cssProperty": "#91dacd",
    "cssValue": "#ece7cd",
    "cssUnit": "#addb67",
    "cssSelector": "#6dbdfa",
    "cssPseudo": "#6dbdfa",
    "markupHeading": "#4FB4D8",
    "markupBold": "#57cdff",
    "markupItalic": "#C792EA",
    "markupCode": "#f7ecb5",
    "markupLink": "#78bd65",
    "markupLinkUrl": "#78BD65",
    "markupQuote": "#78bd65",
    "markupList": "#6dbdfa",
    "diffInserted": "#99b76d",
    "diffDeleted": "#ef5350",
    "invalid": "#6dbdfa",
    "deprecated": "#6dbdfa",
    "meta": "#6dbdfa"
  }
}
