{
  "$schema": "https://raw.githubusercontent.com/calebephrem/github-syntax-theme-store/refs/heads/main/schema.json",
  "name": "C/C++ Themes",
  "description": "Port of VSCode's Visual Studio 2019 Dark theme for GitHub syntax highlighting",
  "author": "calebephrem",
  "type": "dark",
  "syntaxHighlighting": {
    "comment": "#6A9955",
    "constant": "#569cd6",
    "constantNumeric": "#b5cea8",
    "constantBuiltin": "#569cd6",
    "keyword": "#569cd6",
    "keywordControl": "#C586C0",
    "keywordOperator": "#569cd6",
    "operator": "#d4d4d4",
    "string": "#ce9178",
    "stringRegexp": "#d16969",
    "stringEscape": "#FFD68F",
    "stringSpecial": "#569cd6",
    "variable": "#9CDCFE",
    "variableParameter": "#9A9A9A",
    "variableBuiltin": "#569cd6",
    "functionName": "#DCDCAA",
    "functionCall": "#DCDCAA",
    "functionBuiltin": "#569cd6",
    "typeName": "#4EC9B0",
    "typeBuiltin": "#4EC9B0",
    "typeAnnotation": "#4EC9B0",
    "namespace": "#C8C8C8",
    "attribute": "#9cdcfe",
    "attributeValue": "#d7ba7d",
    "tag": "#569cd6",
    "tagPunctuation": "#808080",
    "decorator": "#569cd6",
    "punctuation": "#B4B4B4",
    "bracket": "#808080",
    "property": "#DADADA",
    "cssProperty": "#9cdcfe",
    "cssValue": "#CE9178",
    "cssUnit": "#b5cea8",
    "cssSelector": "#d7ba7d",
    "cssPseudo": "#d7ba7d",
    "markupHeading": "#569cd6",
    "markupBold": "#569cd6",
    "markupItalic": "#ce9178",
    "markupCode": "#ce9178",
    "markupLink": "#569cd6",
    "markupLinkUrl": "#9cdcfe",
    "markupQuote": "#6A9955",
    "markupList": "#6796e6",
    "diffInserted": "#b5cea8",
    "diffDeleted": "#ce9178",
    "invalid": "#f44747",
    "deprecated": "#9A9A9A",
    "meta": "#569cd6"
  }
}
